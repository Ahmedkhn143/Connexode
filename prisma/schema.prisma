generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum ApplicationType {
  AMBASSADOR
  INTERNSHIP
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum UserRole {
  STUDENT
  AMBASSADOR
  MENTOR
  ADMIN
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String?
  role           UserRole @default(STUDENT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications    Application[]
  certificate     Certificate?
  ambassadorStats AmbassadorStats?
  internStats     InternStats?
  projects        Project[]
}

// ─── APPLICATION ─────────────────────────────────────────────────────────────

model Application {
  id           String            @id @default(cuid())
  type         ApplicationType
  status       ApplicationStatus @default(PENDING)

  fullName     String
  email        String
  university   String
  semester     String
  city         String
  whyJoin      String
  availability String?

  instagram    String?
  linkedin     String?

  track        String?
  github       String?
  portfolio    String?
  experience   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  ambassadorStats AmbassadorStats?
  internStats     InternStats?
  projects        Project[]
}

// ─── CERTIFICATE ─────────────────────────────────────────────────────────────

model Certificate {
  id       String            @id @default(cuid())
  certId   String            @unique
  userId   String            @unique
  user     User              @relation(fields: [userId], references: [id])
  type     ApplicationType
  track    String?
  issuedAt DateTime          @default(now())
  status   CertificateStatus @default(ACTIVE)
}

// ─── AMBASSADOR STATS ────────────────────────────────────────────────────────

model AmbassadorStats {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  applicationId   String      @unique
  application     Application @relation(fields: [applicationId], references: [id])
  sessionsHosted  Int         @default(0)
  webinarsHosted  Int         @default(0)
  communityReach  Int         @default(0)
  updatedAt       DateTime    @updatedAt
}

// ─── INTERN STATS ────────────────────────────────────────────────────────────

model InternStats {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  applicationId   String      @unique
  application     Application @relation(fields: [applicationId], references: [id])
  tasksCompleted  Int         @default(0)
  totalScore      Float       @default(0)
  averageScore    Float       @default(0)
  updatedAt       DateTime    @updatedAt
}

// ─── PROJECT ─────────────────────────────────────────────────────────────────

model Project {
  id            String      @id @default(cuid())
  title         String
  description   String
  stack         String[]
  githubUrl     String?
  liveUrl       String?
  score         Int         @default(0)
  published     Boolean     @default(false)
  featured      Boolean     @default(false)
  internId      String
  intern        User        @relation(fields: [internId], references: [id])
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  completedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ─── SUCCESS STORY ───────────────────────────────────────────────────────────

model SuccessStory {
  id          String   @id @default(cuid())
  name        String
  university  String
  role        String
  quote       String
  outcomeStat String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
